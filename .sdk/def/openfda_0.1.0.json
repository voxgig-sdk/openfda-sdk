  "components": {
    "parameters": {
      "SearchParam": {
        "name": "search",
        "in": "query",
        "description": "Search query using openFDA query syntax. Supports logical operators (AND, OR), field-specific searches, and range queries.",
        "required": false,
        "schema": {
          "type": "string"
        },
        "example": "patient.drug.openfda.brand_name:lipitor"
      },
      "CountParam": {
        "name": "count",
        "in": "query",
        "description": "Count records by specified field. Returns frequency counts for unique values.",
        "required": false,
        "schema": {
          "type": "string"
        },
        "example": "patient.reaction.reactionmeddrapt.exact"
      },
      "LimitParam": {
        "name": "limit",
        "in": "query",
        "description": "Number of records to return. Maximum is 1000.",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 1,
          "minimum": 1,
          "maximum": 1000
        }
      },
      "SkipParam": {
        "name": "skip",
        "in": "query",
        "description": "Number of records to skip for pagination. Used with limit for paging through results.",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 0,
          "minimum": 0
        }
      }
    },
    "schemas": {
      "APIResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "disclaimer": {
                "type": "string",
                "description": "Important disclaimer about FDA data usage"
              },
              "terms": {
                "type": "string",
                "description": "Link to API terms of service"
              },
              "license": {
                "type": "string",
                "description": "Link to data license"
              },
              "last_updated": {
                "type": "string",
                "format": "date",
                "description": "Date the data was last updated"
              },
              "results": {
                "type": "object",
                "properties": {
                  "skip": {
                    "type": "integer",
                    "description": "Number of records skipped"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Number of records returned"
                  },
                  "total": {
                    "type": "integer",
                    "description": "Total number of matching records"
                  }
                }
              }
            }
          },
          "results": {
            "type": "array",
            "description": "Array of result objects matching the query",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "message": {
                "type": "string",
                "description": "Error message"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Optional API key for higher rate limits. Without a key, requests are limited to 240 per minute and 1000 per day. With a key, limits increase to 240 per minute and 120000 per day."
      }
    }
  },
  "security": [
    {},
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Drug",
      "description": "Endpoints for querying drug-related data including adverse events, labels, NDC codes, enforcement actions, and shortages"
    },
    {
      "name": "Device",
      "description": "Endpoints for querying medical device data including adverse events, recalls, classifications, and approvals"
    },
    {
      "name": "Food",
      "description": "Endpoints for querying food-related data including adverse events and enforcement reports"
    },
    {
      "name": "Cosmetic",
      "description": "Endpoints for querying cosmetic adverse event data"
    },
    {
      "name": "Tobacco",
      "description": "Endpoints for querying tobacco product problem reports"
    },
    {
      "name": "Other",
      "description": "Other FDA data endpoints including substances and nutritional supplements"
    }
  ],
  "externalDocs": {
    "description": "Full openFDA API Documentation",
    "url": "https://open.fda.gov/apis/"
  }
}
