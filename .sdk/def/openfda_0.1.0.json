{
  "openapi": "3.0.3",
  "info": {
    "title": "openFDA API",
    "description": "openFDA provides access to a variety of public data related to FDA-regulated products. It offers APIs for searching FDA data for drugs, devices, food, and other relevant categories crucial for healthcare decisions and research.",
    "version": "1.0.0",
    "contact": {
      "name": "openFDA",
      "url": "https://open.fda.gov/"
    },
    "license": {
      "name": "Public Domain",
      "url": "https://open.fda.gov/license/"
    }
  },
  "servers": [
    {
      "url": "https://api.fda.gov",
      "description": "Production server"
    }
  ],
  "paths": {
    "/drug/event.json": {
      "get": {
        "summary": "Search drug adverse events",
        "description": "Query FDA Adverse Event Reporting System (FAERS) data for drug adverse events",
        "operationId": "searchDrugEvents",
        "tags": [
          "Drug"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search query using openFDA query syntax",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "patient.drug.openfda.brand_name:aspirin"
          },
          {
            "name": "count",
            "in": "query",
            "description": "Count records by specified field",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of records to return (max 1000)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "maximum": 1000
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of records to skip for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object",
                      "properties": {
                        "disclaimer": {
                          "type": "string"
                        },
                        "terms": {
                          "type": "string"
                        },
                        "license": {
                          "type": "string"
                        },
                        "results": {
                          "type": "object",
                          "properties": {
                            "skip": {
                              "type": "integer"
                            },
                            "limit": {
                              "type": "integer"
                            },
                            "total": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query parameters"
          },
          "404": {
            "description": "No results found"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
